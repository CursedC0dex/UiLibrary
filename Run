-- Creating UI Library Window
local Window = kavo.CreateLib {
	name = "Cursed Library"
}

-- Creating Tabs
local Tab = Window:NewTab({
	name = "Preview Tab ",
	icon = "rbxassetid://6764432408"
})

-- Creating Buttons
local Button = Tab:NewButton({
name = "My Button", 
callback = function()
	print("hi") 
end})

-- Creating Labels
local Label = Tab:NewLabel({
	message = "Preview Label", 
})

local Info = Tab:NewInfo({	
	message = "Preview Info Label",
})

local WarningLabel = Tab:NewWarning({	
	message = "Preview Warning Label",
})

-- Creating Sliders
local Slider = Tab:NewSlider({
title = "Preview Slider",
min = 0,
max = 500,
callback = function(value)
	game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = value 
end})

-- Creating Toggles
local Toggle = Tab:NewToggle({
	title = "Preview Toggle",
	callback = function(state)
		local state = true
		if state then
			print("On")
		else
			print("off")
		end
	end,
})

-- Creating Dropdowns
local Dropdown = Tab:NewDropDown({
	title = "Preview DropDown",
	callback = function(v)
		game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
	end,
})

Dropdown:Add("WS 50", 50)

Dropdown:Add("WS 100", 100)

Dropdown:Add("WS 10", 10)

-- Creating Textboxes
local TextBox = Tab:NewTextBox({
	title = "Preview TextBox",
	placeholder = "...",
	callback = function(text)
		print(text)
	end
})

-- Creating Keybinds
local KeyBind = Tab:NewKeyBind({
	title = "Preview KeyBind",
	defaultKey = "F",
	defaultEnabled = true,
	callback = function(key, isEnabled)
		if isEnabled then
			print("Key " .. key .. " pressed!")
		end
	end
})
